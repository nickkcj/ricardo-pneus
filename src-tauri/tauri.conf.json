{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ricardo Pneus",
  "version": "0.1.2",
  "identifier": "com.nicholasjasper.ricardo-pneus",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ricardo Pneus - Sistema de Gestão",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/backend-api"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/nickkcj/ricardo-pneus/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFRjhCRTFEQ0NBMUI4QUMKUldTc3VLSE1IYjc0YnJkNVlld0wrN1FUdVRWNHp6STNyZC8xK0dUZFB2cWNUbm1QMmpPWFRrK3YK"
    }
  }
}
